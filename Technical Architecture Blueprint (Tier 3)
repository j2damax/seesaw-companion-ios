## 14. Integration with iOS `CloudAgentService`

From the Tier 2 blueprint, the iOS `CloudAgentService` calls Tier 3 as follows: 
```swift
// In seesaw-companion-ios: CloudAgentService.swift
actor CloudAgentService {
    
    let baseURL = "https://seesaw-cloud-agent-[hash]-uc.a.run.app"
    
    func startSession(context: SceneContext, onDeviceBeat: StoryBeat, profile: ChildProfile) async throws -> EnhancedBeat? {
        guard let authToken = try? await Auth.auth().currentUser?.getIDToken() else { return nil }
        
        let request = StoryStartRequest(
            session_id: currentSessionId,
            child_profile: profile,
            scene_context: context,
            on_device_beat: onDeviceBeat
        )
        
        var urlRequest = URLRequest(url: URL(string: "\(baseURL)/story/start")!)
        urlRequest.httpMethod = "POST"
        urlRequest.setValue("Bearer \(authToken)", forHTTPHeaderField: "Authorization")
        urlRequest.setValue("application/json", forHTTPHeaderField: "Content-Type")
        urlRequest.httpBody = try JSONEncoder().encode(request)
        urlRequest.timeoutInterval = 10  // Non-blocking; if slow, Track A already played
        
        let (data, _) = try await URLSession.shared.data(for: urlRequest)
        return try JSONDecoder().decode(StoryStartResponse.self, from: data).enhanced_beat
    }
}
```

The iOS `CompanionViewModel` calls this **fire-and-forget** in a background `Task`:

```swift
Task(priority: .background) {
    if let enhanced = try? await cloudAgentService.startSession(...) {
        await sessionManager.queueEnhancedBeat(enhanced)
        // Plays on NEXT turn, not current
    }
}
```

